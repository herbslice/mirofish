# MiroFish LLM configuration
# Copy to .env and choose one provider.
# Simulations can consume significant tokens. Start with small round counts.

# Provider options:
#   anthropic  - Anthropic API
#   openai     - OpenAI API or any OpenAI-compatible API
#   codex-cli  - optional local Codex CLI integration
LLM_PROVIDER=openai

# ===== OpenAI / OpenAI-compatible API =====
# For OpenAI:
# LLM_API_KEY=your_openai_api_key
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini

# For OpenAI-compatible services (OpenRouter, LiteLLM, vLLM, LM Studio,
# Ollama OpenAI endpoint, MLX server, etc.):
LLM_API_KEY=your_key_or_dummy_value_for_local_servers
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL_NAME=your-model-name

# ===== Anthropic API =====
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key
# LLM_MODEL_NAME=claude-sonnet-4-20250514

# ===== Codex CLI (optional / experimental) =====
# LLM_PROVIDER=codex-cli

# ===== Graph Database Configuration =====
# KuzuDB is embedded; no external graph service is required.
# GRAPH_DB_PATH=./backend/data/graphdb

# ===== Server Configuration =====
# FLASK_DEBUG=false
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Simulation defaults =====
# OASIS_DEFAULT_MAX_ROUNDS=10
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5
